# ------------------------------------------------------------------
# Google Chat Wellness Bot - environment configuration
# Copy to .env and fill in the values before `docker compose up -d`
# ------------------------------------------------------------------

# --- Server ---
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# --- Database (SQLite via Prisma) ---
DATABASE_URL=file:/data/database.db

# --- Google Chat ---
# Path to the Google service account JSON key (mounted into the container).
GOOGLE_SERVICE_ACCOUNT_FILE=/data/service-account.json
# Resource name of the employee working space, e.g. spaces/AAAAxxxx
GOOGLE_CHAT_EMPLOYEE_SPACE=spaces/AAAAAAAAAAA
# Resource name of the manager report space
GOOGLE_CHAT_MANAGER_SPACE=spaces/BBBBBBBBBBB
# Shared token used to verify inbound webhook requests when GOOGLE_CHAT_AUDIENCE
# is not set (local/dev). Append it as ?token=... on the App URL.
GOOGLE_CHAT_VERIFICATION_TOKEN=change-me
# Google Cloud PROJECT NUMBER. When set, inbound webhooks are verified via the
# Google-signed JWT (production-grade). Leave empty to use the static token above.
GOOGLE_CHAT_AUDIENCE=

# --- AI (Claude Code CLI) ---
CLAUDE_CODE_ENABLED=true
# Executable used to invoke Claude Code (reuses the machine OAuth session).
CLAUDE_CODE_BIN=claude
# Max milliseconds to wait for a single Claude Code generation before killing it.
CLAUDE_TIMEOUT_MS=60000

# --- Timezones ---
TIMEZONE=Asia/Seoul
US_TIMEZONE=America/New_York

# --- Working schedule (Asia/Seoul, HH:mm) ---
WORK_START=02:00
WORK_END=11:00
LUNCH_START=04:00
LUNCH_END=05:00

# --- Check-in / reminder timing (minutes) ---
CHECK_INTERVAL=30
FIRST_REMINDER=5
SECOND_REMINDER=5
THIRD_REMINDER=5

# --- Reports ---
REPORT_TIME=11:05

# --- AI history ---
AI_HISTORY_DAYS=30
